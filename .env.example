# Environment configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# 🚀 QUICK START (Recommended Default):
# MODE = mcp-std
# - You don't need any API key for this mode
# - Just run it, and your cloud AI agent can connect to it as a MCP server
# =============================================================================

# Running Mode:
# - mcp-std: **(Recommended)** Standard MCP protocol server, exposes local tools to cloud AI agent
# - mcp-server: Custom MCP API (legacy, keep for compatibility)
# - mcp-client: All inference goes to cloud Gabriel MCP, you chat in Athena window locally
# - standalone: Standalone inference with your own LLM API key, run completely local
# - gui: Desktop GUI chat
MODE=mcp-std

# Cloud Gabriel MCP connection (for mcp-client mode only)
GABRIEL_MCP_URL=http://10.0.0.1:8643
GABRIEL_MCP_API_KEY=

# =============================================================================
# 🔑 LLM Configuration (for standalone mode only)
# Fill these ONLY if you use standalone mode
# Supports any OpenAI-compatible API: doubao, deepseek, openai, siliconflow, etc.
# =============================================================================
LLM_PROVIDER=doubao
LLM_MODEL=doubao-seed-2-0-lite-260428
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# Custom System Prompt / Agent Identity (leave empty for default)
SYSTEM_PROMPT=

# Local Ollama configuration (always keep this, even for mcp-std mode)
# Used by Ollama tools to manage local models
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Server configuration
HOST=0.0.0.0
PORT=8000

# Data directory (for sessions and logs)
DATA_DIR=./data
